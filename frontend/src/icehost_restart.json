{
  "name": "icehost_restart",
  "label": "IceHost 重启",
  "url": "https://dash.icehost.pl/server/5125dd82",
  "timeout": 180000,
  "script": [
    "async function(ctx) {",
    "  const notifyId = '5878981847';",
    "  const clean = (text) => (text || '').replace(/\\s+/g, ' ').trim();",
    "  const dePolish = (text) => clean(text)",
    "    .replace(/[ąĄ]/g, 'a')",
    "    .replace(/[ćĆ]/g, 'c')",
    "    .replace(/[ęĘ]/g, 'e')",
    "    .replace(/[łŁ]/g, 'l')",
    "    .replace(/[ńŃ]/g, 'n')",
    "    .replace(/[óÓ]/g, 'o')",
    "    .replace(/[śŚ]/g, 's')",
    "    .replace(/[żŻ]/g, 'z')",
    "    .replace(/[źŹ]/g, 'z');",
    "  const extractDateTime = (text) => {",
    "    const m = clean(text).match(/(\\d{4}-\\d{2}-\\d{2}\\s+\\d{2}:\\d{2}:\\d{2})/);",
    "    return m ? m[1] : '';",
    "  };",
    "",
    "  const readExpiryText = () => {",
    "    const nodes = Array.from(document.querySelectorAll('p, span, div, li, strong, b'));",
    "    for (const el of nodes) {",
    "      const text = clean(el.textContent || '');",
    "      if (!text) continue;",
    "      if (!/data\\s+w[aą]zno[sś]ci/i.test(text)) continue;",
    "      const dt = extractDateTime(text);",
    "      if (dt) return dt;",
    "    }",
    "",
    "    const bodyText = clean(document.body && document.body.innerText ? document.body.innerText : '');",
    "    const labeled = bodyText.match(/data\\s+w[aą]zno[sś]ci[^0-9]*(\\d{4}-\\d{2}-\\d{2}\\s+\\d{2}:\\d{2}:\\d{2})/i);",
    "    if (labeled) return labeled[1];",
    "",
    "    return extractDateTime(bodyText);",
    "  };",
    "",
    "  const parseMs = (text) => {",
    "    const m = clean(text).match(/(\\d{4})-(\\d{2})-(\\d{2})\\s+(\\d{2}):(\\d{2}):(\\d{2})/);",
    "    if (!m) return NaN;",
    "    const ms = new Date(`${m[1]}-${m[2]}-${m[3]}T${m[4]}:${m[5]}:${m[6]}`).getTime();",
    "    return Number.isFinite(ms) ? ms : NaN;",
    "  };",
    "",
    "  const findRenewBtn = () => {",
    "    const byId = document.querySelector('#renew-free-server-btn');",
    "    if (byId) return byId;",
    "",
    "    const selectors = [",
    "      'button',",
    "      'a',",
    "      'input[type=\"button\"]',",
    "      'input[type=\"submit\"]',",
    "      '[role=\"button\"]',",
    "      '[class*=\"btn\"]',",
    "      '[class*=\"button\"]'",
    "    ].join(', ');",
    "",
    "    const nodes = Array.from(document.querySelectorAll(selectors));",
    "    return nodes.find((el) => {",
    "      const text = dePolish(el.textContent || el.value || '');",
    "      return /dodaj\\s*6\\s*godzin\\s*waznosci/i.test(text) || /renew\\s*\\+?\\s*6\\s*hours?/i.test(text);",
    "    }) || null;",
    "  };",
    "",
    "  const readError = () => {",
    "    const nodes = Array.from(document.querySelectorAll('[role=\"alert\"], .toast, [class*=\"alert\"], [class*=\"error\"]'));",
    "    const row = nodes.find((el) => /nie możesz przedłużyć|nie mozesz przedluzyc|niedawno to zrobiłeś|niedawno to zrobiles/i.test(clean(el.textContent || '')));",
    "    return row ? clean(row.textContent || '') : '';",
    "  };",
    "",
    "  const waitReadyDeadline = Date.now() + 30000;",
    "  let btn = null;",
    "  let beforeText = '';",
    "  let beforeMs = NaN;",
    "  while (Date.now() < waitReadyDeadline) {",
    "    await ctx.wait(1000);",
    "    btn = findRenewBtn();",
    "    beforeText = readExpiryText();",
    "    beforeMs = parseMs(beforeText);",
    "    if (btn && !Number.isNaN(beforeMs)) break;",
    "  }",
    "",
    "  if (!btn) {",
    "    return {",
    "      success: false,",
    "      message: '续期失败，未找到按钮：DODAJ 6 GODZIN WAZNOSCI',",
    "      keepOpen: false,",
    "      variables: { shutdownTime: beforeText || 'unknown', tg_notify_chat_id: notifyId }",
    "    };",
    "  }",
    "",
    "  if (Number.isNaN(beforeMs)) {",
    "    return {",
    "      success: false,",
    "      message: `续期失败，读取有效期失败：${beforeText || 'empty'}`,",
    "      keepOpen: false,",
    "      variables: { shutdownTime: beforeText || 'unknown', tg_notify_chat_id: notifyId }",
    "    };",
    "  }",
    "",
    "  try { btn.scrollIntoView({ block: 'center' }); } catch (error) {}",
    "  try { btn.removeAttribute('disabled'); } catch (error) {}",
    "  try { btn.click(); } catch (error) {}",
    "  try { btn.dispatchEvent(new MouseEvent('click', { bubbles: true, cancelable: true, view: window })); } catch (error) {}",
    "",
    "  await ctx.wait(10000);",
    "",
    "  const afterText = readExpiryText();",
    "  const afterMs = parseMs(afterText);",
    "",
    "  if (!Number.isNaN(afterMs) && afterMs > beforeMs) {",
    "    return {",
    "      success: true,",
    "      message: `续期成功：${beforeText} -> ${afterText}`,",
    "      keepOpen: false,",
    "      variables: { shutdownTime: afterText, tg_notify_chat_id: notifyId }",
    "    };",
    "  }",
    "",
    "  const err = readError();",
    "  return {",
    "    success: false,",
    "    message: err ? `续期失败：${err}` : `续期失败，有效期未增加：${beforeText} -> ${afterText}`,",
    "    keepOpen: false,",
    "    variables: { shutdownTime: afterText || beforeText, tg_notify_chat_id: notifyId }",
    "  };",
    "}"
  ]
}
