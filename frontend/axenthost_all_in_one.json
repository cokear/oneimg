{
  "name": "axenthost_all_in_one",
  "label": "AxentHost 自动领取+抽奖",
  "url": "https://app.axenthost.com/claim",
  "enabled": true,
  "timeout": 300000,
  "timerMode": "window",
  "cooldownMinutes": 60,
  "windowSeconds": 180,
  "defaultData": {},
  "script": [
    "async function(ctx) {",
    "  const SPIN_INTERVAL_MS = 24 * 60 * 60 * 1000;",
    "  const LS_SPIN_KEY = 'axenthost_spin_last_success_at';",
    "",
    "  const addStyle = (css) => {",
    "    const id = 'axenthost-plugin-ad-style';",
    "    if (document.getElementById(id)) return;",
    "    const style = document.createElement('style');",
    "    style.id = id;",
    "    style.textContent = css;",
    "    document.documentElement.appendChild(style);",
    "  };",
    "",
    "  const parseTimerToMs = (text) => {",
    "    const raw = (text || '').trim();",
    "    if (!raw) return 0;",
    "    const parts = raw.split(':').map((n) => Number(n));",
    "    if (parts.some((n) => !Number.isFinite(n))) return 0;",
    "    if (parts.length === 3) return (parts[0] * 3600 + parts[1] * 60 + parts[2]) * 1000;",
    "    if (parts.length === 2) return (parts[0] * 60 + parts[1]) * 1000;",
    "    return 0;",
    "  };",
    "",
    "  const readClaimsLeft = () => {",
    "    const counter = document.querySelector('.font-s1.mx-auto.mt-2');",
    "    const text = counter ? (counter.textContent || '') : '';",
    "    const match = text.match(/(\\d+)\\s*\\/\\s*5/);",
    "    return match ? Number(match[1]) : null;",
    "  };",
    "",
    "  const getLastSpinAt = () => {",
    "    const value = Number(localStorage.getItem(LS_SPIN_KEY) || 0);",
    "    return Number.isFinite(value) && value > 0 ? value : 0;",
    "  };",
    "",
    "  const setLastSpinAt = (ts) => {",
    "    localStorage.setItem(LS_SPIN_KEY, String(ts));",
    "  };",
    "",
    "  const spinDue = () => {",
    "    const last = getLastSpinAt();",
    "    return !last || Date.now() - last >= SPIN_INTERVAL_MS;",
    "  };",
    "",
    "  const go = async (path, phase) => {",
    "    ctx.variables.phase = phase;",
    "    if (window.location.pathname !== path) {",
    "      window.location.href = path;",
    "      await ctx.wait(250);",
    "    }",
    "    await ctx.reload();",
    "    return { success: true, message: 'reloading' };",
    "  };",
    "",
    "  const finish = (success, message, extra) => ({",
    "    success,",
    "    message,",
    "    variables: {",
    "      ...(ctx.variables || {}),",
    "      ...(extra || {}),",
    "      phase: ''",
    "    }",
    "  });",
    "",
    "  addStyle(`",
    "    [id^=\"ad-\"],",
    "    .premium-ad,",
    "    iframe[src*=\"google\"],",
    "    iframe[id^=\"google_ads\"],",
    "    .adsbygoogle,",
    "    [id^=\"div-gpt-ad\"] {",
    "      opacity: 0 !important;",
    "      pointer-events: none !important;",
    "      position: absolute !important;",
    "      left: -9999px !important;",
    "      height: 0 !important;",
    "      width: 0 !important;",
    "      margin: 0 !important;",
    "      padding: 0 !important;",
    "      overflow: hidden !important;",
    "      z-index: -999 !important;",
    "    }",
    "  `);",
    "",
    "  await ctx.wait(1500);",
    "  const currentPath = window.location.pathname;",
    "  const phase = (ctx.variables && ctx.variables.phase) || '';",
    "",
    "  if (!phase) {",
    "    if (currentPath !== '/claim') {",
    "      return await go('/claim', 'claim');",
    "    }",
    "    ctx.variables.phase = 'claim';",
    "  }",
    "",
    "  if ((phase === 'claim' || ctx.variables.phase === 'claim') && currentPath === '/claim') {",
    "    const disabledTimer = document.querySelector('button.disabled span.font-s4');",
    "    if (!disabledTimer) {",
    "      const claimBtn = document.querySelector('button.btn-gradient-primary:not(.disabled)');",
    "      if (!claimBtn) {",
    "        return { success: false, keepOpen: true, message: '未找到可点击的领取按钮' };",
    "      }",
    "",
    "      const cfTokenEl = document.querySelector('[name=\"cf-turnstile-response\"]');",
    "      if (cfTokenEl) {",
    "        const cfDeadline = Date.now() + 120000;",
    "        while (Date.now() < cfDeadline) {",
    "          const token = (cfTokenEl.value || '').trim();",
    "          if (token.length > 20) break;",
    "          await ctx.wait(1000);",
    "        }",
    "        const finalToken = (cfTokenEl.value || '').trim();",
    "        if (finalToken.length <= 20) {",
    "          return { success: false, keepOpen: true, message: '等待 CF 验证超时，请人工通过后重试' };",
    "        }",
    "      }",
    "",
    "      claimBtn.click();",
    "      const successDeadline = Date.now() + 30000;",
    "      while (Date.now() < successDeadline) {",
    "        const bodyText = (document.body && document.body.innerText) ? document.body.innerText : '';",
    "        if (bodyText.includes('Credits successfully claimed')) {",
    "          break;",
    "        }",
    "        await ctx.wait(1000);",
    "      }",
    "    }",
    "",
    "    const lateTimer = document.querySelector('button.disabled span.font-s4');",
    "    const claimCooldownMs = lateTimer ? parseTimerToMs(lateTimer.textContent || '') : 0;",
    "",
    "    if (spinDue()) {",
    "      return await go('/spin', 'spin');",
    "    }",
    "",
    "    return finish(true, claimCooldownMs > 0",
    "      ? `领取流程完成，抽奖未到 24h（约 ${Math.ceil(claimCooldownMs / 60000)} 分钟后再运行）`",
    "      : '领取流程完成，抽奖未到 24h', {",
    "      ax_claim_cooldown_ms: claimCooldownMs,",
    "      ax_claims_left: readClaimsLeft(),",
    "      ax_spin_due: false",
    "    });",
    "  }",
    "",
    "  if ((phase === 'spin' || ctx.variables.phase === 'spin') && currentPath === '/spin') {",
    "    const timerEl = document.querySelector('span.text-white.font-s4');",
    "    if (timerEl && (timerEl.textContent || '').includes(':')) {",
    "      const spinCooldownMs = parseTimerToMs(timerEl.textContent || '');",
    "      if (spinCooldownMs > 0) {",
    "        setLastSpinAt(Date.now());",
    "        return finish(true, `抽奖已是冷却状态，按 24h 计时处理（约 ${Math.ceil(spinCooldownMs / 60000)} 分钟）`, {",
    "          ax_spin_cooldown_ms: spinCooldownMs,",
    "          ax_spin_due: false,",
    "          ax_spin_last_success_at: getLastSpinAt()",
    "        });",
    "      }",
    "    }",
    "",
    "    const spinBtn = Array.from(document.querySelectorAll('.spin, button, [role=\"button\"]')).find((el) =>",
    "      /\\bspin\\b/i.test((el.textContent || '').trim())",
    "    );",
    "    if (!spinBtn) {",
    "      return { success: false, keepOpen: true, message: '未找到 Spin 按钮' };",
    "    }",
    "",
    "    spinBtn.click();",
    "    const spinDeadline = Date.now() + 45000;",
    "    while (Date.now() < spinDeadline) {",
    "      await ctx.wait(1000);",
    "      const newTimer = document.querySelector('span.text-white.font-s4');",
    "      if (newTimer && (newTimer.textContent || '').includes(':')) {",
    "        const spinCooldownMs = parseTimerToMs(newTimer.textContent || '');",
    "        setLastSpinAt(Date.now());",
    "        return finish(true, `领取+抽奖完成，抽奖进入冷却（约 ${Math.ceil(spinCooldownMs / 60000)} 分钟）`, {",
    "          ax_spin_cooldown_ms: spinCooldownMs,",
    "          ax_spin_due: false,",
    "          ax_spin_last_success_at: getLastSpinAt()",
    "        });",
    "      }",
    "    }",
    "",
    "    return { success: false, keepOpen: true, message: '抽奖后未检测到冷却计时' };",
    "  }",
    "",
    "  if (currentPath !== '/claim') {",
    "    return await go('/claim', 'claim');",
    "  }",
    "",
    "  return finish(true, '流程结束');",
    "}"
  ]
}
