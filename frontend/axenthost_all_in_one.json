{
  "name": "axenthost_all_in_one",
  "label": "AxentHost 自动领取+抽奖",
  "url": "https://app.axenthost.com/claim",
  "enabled": true,
  "timeout": 300000,
  "timerMode": "window",
  "cooldownMinutes": "60-70",
  "windowSeconds": 0,
  "defaultData": {},
  "script": [
    "async function(ctx) {",
    "  const notifyId = '5878981847';",
    "",
    "  const addStyle = (css) => {",
    "    const id = 'axenthost-plugin-ad-style';",
    "    if (document.getElementById(id)) return;",
    "    const style = document.createElement('style');",
    "    style.id = id;",
    "    style.textContent = css;",
    "    document.documentElement.appendChild(style);",
    "  };",
    "",
    "  const parseTimerToMs = (text) => {",
    "    const raw = (text || '').trim();",
    "    if (!raw) return 0;",
    "    const parts = raw.split(':').map((n) => Number(n));",
    "    if (parts.some((n) => !Number.isFinite(n))) return 0;",
    "    if (parts.length === 3) return (parts[0] * 3600 + parts[1] * 60 + parts[2]) * 1000;",
    "    if (parts.length === 2) return (parts[0] * 60 + parts[1]) * 1000;",
    "    return 0;",
    "  };",
    "",
    "  const readClaimsLeft = () => {",
    "    const el = document.querySelector('.font-s1.mx-auto.mt-2');",
    "    const text = el ? (el.textContent || '') : '';",
    "    const match = text.match(/(\\d+)\\s*\\/\\s*5/);",
    "    return match ? Number(match[1]) : null;",
    "  };",
    "",
    "  const finish = (success, message, extra) => ({",
    "    success,",
    "    message,",
    "    variables: {",
    "      ...(ctx.variables || {}),",
    "      ...(extra || {}),",
    "      tg_notify_chat_id: notifyId,",
    "      phase: ''",
    "    }",
    "  });",
    "",
    "  const fail = (message, extra) => ({",
    "    success: false,",
    "    keepOpen: true,",
    "    message,",
    "    variables: {",
    "      ...(ctx.variables || {}),",
    "      ...(extra || {}),",
    "      tg_notify_chat_id: notifyId,",
    "      phase: ''",
    "    }",
    "  });",
    "",
    "  const go = async (path, phase) => {",
    "    ctx.variables.phase = phase;",
    "    if (window.location.pathname !== path) {",
    "      window.location.href = path;",
    "      await ctx.wait(300);",
    "    }",
    "    await ctx.reload();",
    "    return { success: true, message: 'reloading' };",
    "  };",
    "",
    "  addStyle(`",
    "    [id^=\"ad-\"],",
    "    .premium-ad,",
    "    iframe[src*=\"google\"],",
    "    iframe[id^=\"google_ads\"],",
    "    .adsbygoogle,",
    "    [id^=\"div-gpt-ad\"] {",
    "      opacity: 0 !important;",
    "      pointer-events: none !important;",
    "      position: absolute !important;",
    "      left: -9999px !important;",
    "      height: 0 !important;",
    "      width: 0 !important;",
    "      margin: 0 !important;",
    "      padding: 0 !important;",
    "      overflow: hidden !important;",
    "      z-index: -999 !important;",
    "    }",
    "  `);",
    "",
    "  await ctx.wait(2000);",
    "  const phase = (ctx.variables && ctx.variables.phase) || '';",
    "  const path = window.location.pathname;",
    "",
    "  if (!phase) {",
    "    if (path !== '/claim') {",
    "      return await go('/claim', 'claim');",
    "    }",
    "    ctx.variables.phase = 'claim';",
    "  }",
    "",
    "  if ((phase === 'claim' || ctx.variables.phase === 'claim') && path === '/claim') {",
    "    const claimTimer = document.querySelector('button.disabled span.font-s4');",
    "    if (!claimTimer) {",
    "      const claimBtn = document.querySelector('button.btn-gradient-primary:not(.disabled)');",
    "      if (!claimBtn) return fail('未找到可点击的领取按钮');",
    "",
    "      const cfToken = document.querySelector('[name=\"cf-turnstile-response\"]');",
    "      if (cfToken) {",
    "        const deadline = Date.now() + 120000;",
    "        while (Date.now() < deadline) {",
    "          if ((cfToken.value || '').trim().length > 20) break;",
    "          await ctx.wait(1000);",
    "        }",
    "        if ((cfToken.value || '').trim().length <= 20) {",
    "          return fail('等待 CF 验证超时，请人工通过后重试');",
    "        }",
    "      }",
    "",
    "      claimBtn.click();",
    "      const deadline = Date.now() + 30000;",
    "      let claimed = false;",
    "      while (Date.now() < deadline) {",
    "        const bodyText = document.body && document.body.innerText ? document.body.innerText : '';",
    "        if (bodyText.includes('Credits successfully claimed')) {",
    "          claimed = true;",
    "          break;",
    "        }",
    "        await ctx.wait(1000);",
    "      }",
    "      if (!claimed) {",
    "        return fail('点击领取后未检测到成功提示', { ax_claims_left: readClaimsLeft() });",
    "      }",
    "    }",
    "",
    "    return await go('/spin', 'spin');",
    "  }",
    "",
    "  if ((phase === 'spin' || ctx.variables.phase === 'spin') && path === '/spin') {",
    "    const spinTimer = document.querySelector('span.text-white.font-s4');",
    "    if (spinTimer && (spinTimer.textContent || '').includes(':')) {",
    "      const ms = parseTimerToMs(spinTimer.textContent || '');",
    "      return finish(true, ms > 0",
    "        ? `领取完成，抽奖冷却中（约 ${Math.ceil(ms / 60000)} 分钟）`",
    "        : '领取完成，抽奖处于冷却', {",
    "        ax_spin_cooldown_ms: ms,",
    "        ax_claims_left: readClaimsLeft()",
    "      });",
    "    }",
    "",
    "    const spinBtn = Array.from(document.querySelectorAll('.spin, button, [role=\"button\"]')).find((el) =>",
    "      /\\bspin\\b/i.test((el.textContent || '').trim())",
    "    );",
    "    if (!spinBtn) return fail('未找到 Spin 按钮');",
    "",
    "    spinBtn.click();",
    "    const deadline = Date.now() + 45000;",
    "    while (Date.now() < deadline) {",
    "      await ctx.wait(1000);",
    "      const newTimer = document.querySelector('span.text-white.font-s4');",
    "      if (newTimer && (newTimer.textContent || '').includes(':')) {",
    "        const ms = parseTimerToMs(newTimer.textContent || '');",
    "        return finish(true, `领取+抽奖完成，抽奖进入冷却（约 ${Math.ceil(ms / 60000)} 分钟）`, {",
    "          ax_spin_cooldown_ms: ms,",
    "          ax_claims_left: readClaimsLeft()",
    "        });",
    "      }",
    "    }",
    "",
    "    return fail('抽奖后未检测到冷却计时');",
    "  }",
    "",
    "  return await go('/claim', 'claim');",
    "}"
  ]
}
