{
  "name": "runox_restart",
  "label": "Runox 重启",
  "url": "https://runox.io/dashboard/servers/cml2bbz6n008cnk1shodcjsfm",
  "script": [
    "async function(ctx) {",
    "  const notifyId = '5878981847';",
    "",
    "  const readSessionText = () => {",
    "    const heading = Array.from(document.querySelectorAll('h3')).find((el) => /session\\s*time\\s*remaining/i.test((el.textContent || '').trim()));",
    "    if (heading) {",
    "      const card = heading.closest('div');",
    "      const p = card ? card.querySelector('p') : null;",
    "      const text = p ? (p.textContent || '').trim() : '';",
    "      if (text) return text;",
    "    }",
    "",
    "    const pMatch = Array.from(document.querySelectorAll('p')).find((el) => /hours?\\s*(?:y|and)?\\s*\\d+\\s*minutes?/i.test((el.textContent || '').trim()) || /will\\s*end\\s*in/i.test((el.textContent || '').trim()));",
    "    if (pMatch) return (pMatch.textContent || '').trim();",
    "",
    "    return (document.body && document.body.innerText ? document.body.innerText : '').replace(/\\s+/g, ' ').trim();",
    "  };",
    "",
    "  const parseMinutes = (text) => {",
    "    const normalized = (text || '').toLowerCase().replace(/[.,]/g, ' ').replace(/\\s+/g, ' ').trim();",
    "    if (!normalized) return NaN;",
    "",
    "    const hm = normalized.match(/(\\d+)\\s*hours?\\s*(?:y|and)?\\s*(\\d+)\\s*minutes?/i);",
    "    if (hm) return Number(hm[1]) * 60 + Number(hm[2]);",
    "",
    "    const compact = normalized.match(/(\\d+)h\\s*(\\d+)m/i);",
    "    if (compact) return Number(compact[1]) * 60 + Number(compact[2]);",
    "",
    "    const hOnly = normalized.match(/(\\d+)\\s*hours?/i);",
    "    if (hOnly) return Number(hOnly[1]) * 60;",
    "",
    "    return NaN;",
    "  };",
    "",
    "  const toShort = (text) => {",
    "    const normalized = (text || '').toLowerCase().replace(/[.,]/g, ' ').replace(/\\s+/g, ' ').trim();",
    "    const hm = normalized.match(/(\\d+)\\s*hours?\\s*(?:y|and)?\\s*(\\d+)\\s*minutes?/i);",
    "    if (hm) return `${Number(hm[1])}h${Number(hm[2])}m`;",
    "    return (text || '').trim() || 'unknown';",
    "  };",
    "",
    "  await ctx.wait(5000);",
    "  const beforeRaw = readSessionText();",
    "  const beforeMinutes = parseMinutes(beforeRaw);",
    "  if (Number.isNaN(beforeMinutes)) {",
    "    return {",
    "      success: false,",
    "      message: `重启失败，无法读取初始时间：${beforeRaw || 'empty'}`,",
    "      keepOpen: true,",
    "      variables: { shutdownTime: beforeRaw || 'unknown', tg_notify_chat_id: notifyId }",
    "    };",
    "  }",
    "",
    "  const killBtn = Array.from(document.querySelectorAll('button, [role=\"button\"]')).find((el) => {",
    "    const title = (el.getAttribute('title') || '').trim();",
    "    const text = (el.textContent || '').trim();",
    "    return /force\\s*kill\\s*the\\s*server\\s*process/i.test(title) || /^kill$/i.test(text) || /\\bkill\\b/i.test(text);",
    "  });",
    "  if (!killBtn) {",
    "    return {",
    "      success: false,",
    "      message: `重启失败，未找到 Kill 按钮（当前：${toShort(beforeRaw)}）`,",
    "      keepOpen: true,",
    "      variables: { shutdownTime: beforeRaw, tg_notify_chat_id: notifyId }",
    "    };",
    "  }",
    "",
    "  killBtn.click();",
    "  await ctx.wait(10000);",
    "",
    "  const startBtn = document.querySelector('form[action*=\"/power\"] button[name=\"intent\"][value=\"start\"]') || Array.from(document.querySelectorAll('button, [role=\"button\"]')).find((el) => /^start$/i.test((el.textContent || '').trim()));",
    "  if (!startBtn) {",
    "    return {",
    "      success: false,",
    "      message: `重启失败，未找到 Start 按钮（当前：${toShort(beforeRaw)}）`,",
    "      keepOpen: true,",
    "      variables: { shutdownTime: beforeRaw, tg_notify_chat_id: notifyId }",
    "    };",
    "  }",
    "",
    "  startBtn.click();",
    "",
    "  const deadline = Date.now() + 180000;",
    "  let afterRaw = beforeRaw;",
    "  let afterMinutes = beforeMinutes;",
    "  while (Date.now() < deadline) {",
    "    await ctx.wait(5000);",
    "    afterRaw = readSessionText();",
    "    afterMinutes = parseMinutes(afterRaw);",
    "",
    "    const increased = !Number.isNaN(afterMinutes) && afterMinutes > beforeMinutes;",
    "    const resetByFormat = /\\b2\\s*hours?\\s*(?:y|and)?\\s*59\\s*minutes?\\b/i.test((afterRaw || '').replace(/[.,]/g, ' '));",
    "    const resetByRange = !Number.isNaN(afterMinutes) && afterMinutes >= 175 && afterMinutes <= 180;",
    "",
    "    if (increased && (resetByFormat || resetByRange)) {",
    "      return {",
    "        success: true,",
    "        message: `重启成功，时间已重置：${toShort(beforeRaw)} -> ${toShort(afterRaw)}`,",
    "        variables: { shutdownTime: afterRaw, tg_notify_chat_id: notifyId }",
    "      };",
    "    }",
    "  }",
    "",
    "  return {",
    "    success: false,",
    "    message: `重启失败，时间未重置到 2h59m：${toShort(beforeRaw)} -> ${toShort(afterRaw)}`,",
    "    keepOpen: true,",
    "    variables: { shutdownTime: afterRaw || beforeRaw, tg_notify_chat_id: notifyId }",
    "  };",
    "}"
  ]
}
