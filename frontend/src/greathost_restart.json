{
  "name": "greathost_restart",
  "label": "GreatHost 重启",
  "url": "https://greathost.es/contracts/2f6dfea2-7008-4f19-9101-4d291c1647dc",
  "script": [
    "async function(ctx) {",
    "  const notifyId = '5878981847';",
    "  const readText = () => {",
    "    const el = ctx.query('#free-server-container #accumulated-time') || ctx.query('#accumulated-time');",
    "    return el ? (el.textContent || '').trim() : '';",
    "  };",
    "  const parseHours = (text) => {",
    "    const normalized = (text || '').toLowerCase().replace(/,/g, ' ').replace(/\\s+/g, ' ').trim();",
    "    if (!normalized) return NaN;",
    "    let total = 0;",
    "    const dayMatch = normalized.match(/(\\d+(?:\\.\\d+)?)\\s*(day|days|d)/);",
    "    const hourMatch = normalized.match(/(\\d+(?:\\.\\d+)?)\\s*(hour|hours|hr|hrs|h)/);",
    "    const minuteMatch = normalized.match(/(\\d+(?:\\.\\d+)?)\\s*(minute|minutes|min|mins|m)/);",
    "    if (dayMatch) total += Number(dayMatch[1]) * 24;",
    "    if (hourMatch) total += Number(hourMatch[1]);",
    "    if (minuteMatch) total += Number(minuteMatch[1]) / 60;",
    "    if (total > 0) return total;",
    "    const plainNum = normalized.match(/\\d+(?:\\.\\d+)?/);",
    "    return plainNum ? Number(plainNum[0]) : NaN;",
    "  };",
    "",
    "  await ctx.wait(5000);",
    "  const beforeText = readText();",
    "  const beforeHours = parseHours(beforeText);",
    "  if (!beforeText || Number.isNaN(beforeHours)) {",
    "    return {",
    "      success: false,",
    "      message: `续期失败，读取续期前时间异常：${beforeText || 'empty'}`,",
    "      keepOpen: true,",
    "      variables: { shutdownTime: beforeText || 'unknown', tg_notify_chat_id: notifyId }",
    "    };",
    "  }",
    "",
    "  const renewBtn =",
    "    ctx.query('#free-server-container #renew-free-server-btn') ||",
    "    ctx.query('#renew-free-server-btn') ||",
    "    Array.from(document.querySelectorAll('button, [role=\"button\"]')).find((el) =>",
    "      /renew\\s*\\+?\\s*\\d+\\s*hours?/i.test((el.textContent || '').trim())",
    "    );",
    "",
    "  if (!renewBtn) {",
    "    return {",
    "      success: false,",
    "      message: `续期失败，未找到 Renew 按钮（当前：${beforeText}）`,",
    "      keepOpen: true,",
    "      variables: { shutdownTime: beforeText, tg_notify_chat_id: notifyId }",
    "    };",
    "  }",
    "",
    "  renewBtn.click();",
    "  const deadline = Date.now() + 120000;",
    "  let afterText = beforeText;",
    "  let afterHours = beforeHours;",
    "",
    "  while (Date.now() < deadline) {",
    "    await ctx.wait(5000);",
    "    afterText = readText();",
    "    afterHours = parseHours(afterText);",
    "    if (!Number.isNaN(afterHours) && afterHours > beforeHours) {",
    "      return {",
    "        success: true,",
    "        message: `续期成功，时间已增加：${beforeText} -> ${afterText}`,",
    "        variables: { shutdownTime: afterText, tg_notify_chat_id: notifyId }",
    "      };",
    "    }",
    "  }",
    "",
    "  return {",
    "    success: false,",
    "    message: `续期失败，时间未增加：${beforeText} -> ${afterText}`,",
    "    keepOpen: true,",
    "    variables: { shutdownTime: afterText || beforeText, tg_notify_chat_id: notifyId }",
    "  };",
    "}"
  ]
}
