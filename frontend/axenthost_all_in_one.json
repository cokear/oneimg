{
  "name": "axenthost_all_in_one",
  "label": "AxentHost 自动领取+抽奖",
  "url": "https://app.axenthost.com/claim",
  "enabled": true,
  "timeout": 360000,
  "timerMode": "window",
  "cooldownMinutes": "60-70",
  "windowSeconds": 0,
  "defaultData": {},
  "script": [
    "async function(ctx) {",
    "  const notifyId = '5878981847';",
    "",
    "  const done = (success, message, extra, keepOpen) => ({",
    "    success,",
    "    message,",
    "    keepOpen: !!keepOpen,",
    "    variables: { ...(ctx.variables || {}), ...(extra || {}), tg_notify_chat_id: notifyId }",
    "  });",
    "",
    "  const wait = (ms) => ctx.wait(ms);",
    "  const phase = (ctx.variables && ctx.variables.phase) || '';",
    "",
    "  const go = async (path, nextPhase) => {",
    "    ctx.variables.phase = nextPhase;",
    "    if (window.location.pathname !== path) {",
    "      window.location.href = path;",
    "      await wait(300);",
    "    }",
    "    await ctx.reload();",
    "    return { success: true, message: 'reloading', variables: { ...(ctx.variables || {}), tg_notify_chat_id: notifyId } };",
    "  };",
    "",
    "  const parseTimeTextToMs = (text) => {",
    "    if (!text) return 0;",
    "    const parts = String(text).trim().split(':').map(Number);",
    "    if (parts.some((n) => !Number.isFinite(n))) return 0;",
    "    if (parts.length === 3) return (parts[0] * 3600 + parts[1] * 60 + parts[2]) * 1000;",
    "    if (parts.length === 2) return (parts[0] * 60 + parts[1]) * 1000;",
    "    return 0;",
    "  };",
    "",
    "  const readClaimsLeft = () => {",
    "    const claimsTextEl = document.querySelector('.font-s1.mx-auto.mt-2');",
    "    if (!claimsTextEl) return null;",
    "    const match = (claimsTextEl.innerText || '').match(/(\\d+)\\s*\\/\\s*5/);",
    "    return match ? Number(match[1]) : null;",
    "  };",
    "",
    "  const injectAdCss = () => {",
    "    const id = 'ax-ad-clean-style';",
    "    if (document.getElementById(id)) return;",
    "    const style = document.createElement('style');",
    "    style.id = id;",
    "    style.textContent = `",
    "      [id^=\"ad-\"],",
    "      .premium-ad,",
    "      iframe[src*=\"google\"],",
    "      iframe[id^=\"google_ads\"],",
    "      .adsbygoogle,",
    "      [id^=\"div-gpt-ad\"] {",
    "        opacity: 0 !important;",
    "        pointer-events: none !important;",
    "        position: absolute !important;",
    "        left: -9999px !important;",
    "        height: 0 !important;",
    "        width: 0 !important;",
    "        margin: 0 !important;",
    "        padding: 0 !important;",
    "        overflow: hidden !important;",
    "        z-index: -999 !important;",
    "      }`;",
    "    document.documentElement.appendChild(style);",
    "  };",
    "",
    "  injectAdCss();",
    "  await wait(2000);",
    "",
    "  if (!phase) {",
    "    return await go('/claim', 'claim');",
    "  }",
    "",
    "  if (phase === 'claim') {",
    "    if (window.location.pathname !== '/claim') {",
    "      return await go('/claim', 'claim');",
    "    }",
    "",
    "    const claimDeadline = Date.now() + 180000;",
    "    let clicked = false;",
    "",
    "    while (Date.now() < claimDeadline) {",
    "      const disabledBtnTimer = document.querySelector('button.disabled span.font-s4');",
    "      if (disabledBtnTimer) {",
    "        return await go('/spin', 'spin');",
    "      }",
    "",
    "      const bodyText = document.body && document.body.innerText ? document.body.innerText : '';",
    "      if (bodyText.includes('Credits successfully claimed')) {",
    "        return await go('/spin', 'spin');",
    "      }",
    "",
    "      const cfToken = document.querySelector('[name=\"cf-turnstile-response\"]');",
    "      const claimBtn = document.querySelector('button.btn-gradient-primary:not(.disabled)');",
    "",
    "      if (claimBtn && !clicked) {",
    "        if (cfToken) {",
    "          if ((cfToken.value || '').length > 100) {",
    "            claimBtn.click();",
    "            clicked = true;",
    "          }",
    "        } else {",
    "          claimBtn.click();",
    "          clicked = true;",
    "        }",
    "      }",
    "",
    "      await wait(1000);",
    "    }",
    "",
    "    return done(false, '领取阶段超时，未检测到成功或冷却', { ax_claims_left: readClaimsLeft() }, true);",
    "  }",
    "",
    "  if (phase === 'spin') {",
    "    if (window.location.pathname !== '/spin') {",
    "      return await go('/spin', 'spin');",
    "    }",
    "",
    "    const spinDeadline = Date.now() + 120000;",
    "    let spinClicked = false;",
    "",
    "    while (Date.now() < spinDeadline) {",
    "      const timerEl = document.querySelector('span.text-white.font-s4');",
    "      if (timerEl && (timerEl.innerText || '').includes(':')) {",
    "        const ms = parseTimeTextToMs(timerEl.innerText || '');",
    "        return done(true, ms > 0 ? `抽奖冷却中，约 ${Math.ceil(ms / 60000)} 分钟` : '抽奖冷却中', {",
    "          ax_spin_cooldown_ms: ms,",
    "          ax_claims_left: readClaimsLeft()",
    "        }, false);",
    "      }",
    "",
    "      if (!spinClicked) {",
    "        const spinBtn = Array.from(document.querySelectorAll('.spin')).find((el) => (el.innerText || '').includes('Spin'))",
    "          || Array.from(document.querySelectorAll('button,[role=\"button\"]')).find((el) => (el.innerText || '').includes('Spin'));",
    "        if (spinBtn) {",
    "          spinBtn.click();",
    "          spinClicked = true;",
    "        }",
    "      }",
    "",
    "      await wait(1000);",
    "    }",
    "",
    "    return done(false, '抽奖阶段超时，未检测到冷却计时', {}, true);",
    "  }",
    "",
    "  return await go('/claim', 'claim');",
    "}"
  ]
}
