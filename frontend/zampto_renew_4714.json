{
  "name": "zampto_renew_4714",
  "label": "Zampto 续期 4714",
  "url": "https://dash.zampto.net/server?id=4714",
  "timeout": 180000,
  "script": [
    "async function(ctx) {",
    "  const notifyId = '5878981847';",
    "  const targetText = 'Expiry (Next Renewal): 1 day 23h 59m';",
    "  const targetValue = '1 day 23h 59m';",
    "  const renewStateKey = 'webtask_zampto_renew_4714_state';",
    "  const maxCheckMs = 90000;",
    "",
    "  const clean = (text) => (text || '').replace(/\\s+/g, ' ').trim();",
    "  const norm = (text) => clean(text).toLowerCase();",
    "",
    "  const readExpiryText = () => {",
    "    const nextRenewalEl = document.querySelector('#nextRenewalTime');",
    "    const nextRenewalText = clean(nextRenewalEl ? nextRenewalEl.textContent || '' : '');",
    "    if (nextRenewalText) return `Expiry (Next Renewal): ${nextRenewalText}`;",
    "",
    "    const nodes = Array.from(document.querySelectorAll('p, div, span, li, strong, b'));",
    "    const safeNodes = nodes.filter((el) => {",
    "      const text = clean(el.textContent || '');",
    "      if (!text) return false;",
    "      if (text.length > 160) return false;",
    "      if (/function\\s*\\(|const\\s+|let\\s+|document\\.|addEventListener\\s*\\(/i.test(text)) return false;",
    "      return true;",
    "    });",
    "",
    "    const exactLabel = safeNodes.find((el) => /expiry\\s*\\(\\s*next\\s*renewal\\s*\\)\\s*:/i.test(clean(el.textContent || '')));",
    "    if (exactLabel) return clean(exactLabel.textContent || '');",
    "",
    "    const fallback = safeNodes.find((el) => /expiry/i.test(clean(el.textContent || '')) && /renewal/i.test(clean(el.textContent || '')));",
    "    if (fallback) return clean(fallback.textContent || '');",
    "",
    "    return '';",
    "  };",
    "",
    "  const extractDuration = (text) => {",
    "    const raw = clean(text);",
    "    if (!raw) return '';",
    "    const dayHourMin = raw.match(/(\\d+\\s*days?\\s*\\d+\\s*h\\s*\\d+\\s*m)/i);",
    "    if (dayHourMin) return clean(dayHourMin[1]);",
    "    const hourMin = raw.match(/(\\d+\\s*h\\s*\\d+\\s*m)/i);",
    "    if (hourMin) return clean(hourMin[1]);",
    "    return '';",
    "  };",
    "",
    "  const toExpiryValue = (text) => {",
    "    const raw = clean(text);",
    "    if (!raw) return '';",
    "    const m = raw.match(/expiry\\s*\\(\\s*next\\s*renewal\\s*\\)\\s*:\\s*(.+)/i);",
    "    const tail = clean(m ? m[1] : raw);",
    "    const duration = extractDuration(tail);",
    "    return duration || tail;",
    "  };",
    "",
    "  const loadRenewState = () => {",
    "    try {",
    "      const raw = localStorage.getItem(renewStateKey);",
    "      const parsed = raw ? JSON.parse(raw) : null;",
    "      return parsed && typeof parsed === 'object' ? parsed : null;",
    "    } catch (error) {",
    "      return null;",
    "    }",
    "  };",
    "",
    "  const saveRenewState = (state) => {",
    "    try {",
    "      localStorage.setItem(renewStateKey, JSON.stringify(state));",
    "    } catch (error) {}",
    "  };",
    "",
    "  const clearRenewState = () => {",
    "    try { localStorage.removeItem(renewStateKey); } catch (error) {}",
    "  };",
    "",
    "  const findRenewBtn = () => {",
    "    const selectors = [",
    "      'button',",
    "      'a',",
    "      '[role=\"button\"]',",
    "      'input[type=\"button\"]',",
    "      'input[type=\"submit\"]'",
    "    ].join(', ');",
    "",
    "    const nodes = Array.from(document.querySelectorAll(selectors));",
    "    return nodes.find((el) => {",
    "      const text = clean(el.textContent || el.value || '');",
    "      return /\\brenew\\s*server\\b/i.test(text);",
    "    }) || null;",
    "  };",
    "",
    "  const smartClick = (el) => {",
    "    if (!el) return;",
    "    try { el.scrollIntoView({ block: 'center', inline: 'center' }); } catch (error) {}",
    "    try { el.removeAttribute('disabled'); } catch (error) {}",
    "    const events = ['mouseover', 'mouseenter', 'mousedown', 'mouseup', 'click'];",
    "    for (const type of events) {",
    "      try {",
    "        el.dispatchEvent(new MouseEvent(type, { bubbles: true, cancelable: true, view: window }));",
    "      } catch (error) {}",
    "    }",
    "    try { el.click(); } catch (error) {}",
    "  };",
    "",
    "  const state = loadRenewState();",
    "  const justClicked = !!(state && state.phase === 'clicked' && Number.isFinite(Number(state.ts)) && Date.now() - Number(state.ts) <= maxCheckMs);",
    "",
    "  const readyDeadline = Date.now() + 45000;",
    "  let beforeRaw = '';",
    "  let renewBtn = null;",
    "  while (Date.now() < readyDeadline) {",
    "    await ctx.wait(1000);",
    "    beforeRaw = readExpiryText();",
    "    renewBtn = findRenewBtn();",
    "    if (beforeRaw && (justClicked || renewBtn)) break;",
    "  }",
    "",
    "  if (!beforeRaw) {",
    "    return {",
    "      success: false,",
    "      message: '续期失败，未读取到 Expiry (Next Renewal) 时间',",
    "      keepOpen: true,",
    "      variables: { shutdownTime: 'unknown', tg_notify_chat_id: notifyId }",
    "    };",
    "  }",
    "",
    "  if (!justClicked && !renewBtn) {",
    "    return {",
    "      success: false,",
    "      message: `续期失败，未找到 Renew Server 按钮（续期前：${beforeRaw}）`,",
    "      keepOpen: true,",
    "      variables: { shutdownTime: beforeRaw, tg_notify_chat_id: notifyId }",
    "    };",
    "  }",
    "",
    "  if (!justClicked) {",
    "    saveRenewState({ phase: 'clicked', ts: Date.now(), beforeRaw });",
    "    smartClick(renewBtn);",
    "  }",
    "",
    "  const targetNorm = norm(targetText);",
    "  const targetValueNorm = norm(targetValue);",
    "  const targetDurationNorm = norm(extractDuration(targetValue));",
    "  const checkDeadline = Date.now() + maxCheckMs;",
    "  const beforeShort = toExpiryValue(beforeRaw) || beforeRaw || 'unknown';",
    "  let afterRaw = beforeRaw;",
    "  while (Date.now() < checkDeadline) {",
    "    await ctx.wait(3000);",
    "    const current = readExpiryText();",
    "    if (current) afterRaw = current;",
    "    const afterValue = toExpiryValue(afterRaw);",
    "    const afterDuration = extractDuration(afterRaw);",
    "    const matchByFull = norm(afterRaw) === targetNorm;",
    "    const matchByValue = norm(afterValue) === targetValueNorm;",
    "    const matchByDuration = norm(afterDuration) === targetDurationNorm;",
    "    if (matchByFull || matchByValue || matchByDuration) {",
    "      clearRenewState();",
    "      return {",
    "        success: true,",
    "        message: `续期成功：${beforeShort} -> ${afterValue || afterDuration || 'unknown'}`,",
    "        keepOpen: false,",
    "        variables: { shutdownTime: afterValue || afterDuration || afterRaw, tg_notify_chat_id: notifyId }",
    "      };",
    "    }",
    "  }",
    "",
    "  clearRenewState();",
    "  const afterShort = toExpiryValue(afterRaw) || extractDuration(afterRaw) || afterRaw || 'unknown';",
    "  return {",
    "    success: false,",
    "    message: `续期失败，未达到目标值（目标：${targetValue}；实际：${afterShort}）`,",
    "    keepOpen: true,",
    "    variables: { shutdownTime: afterShort || beforeShort, tg_notify_chat_id: notifyId }",
    "  };",
    "}"
  ]
}
